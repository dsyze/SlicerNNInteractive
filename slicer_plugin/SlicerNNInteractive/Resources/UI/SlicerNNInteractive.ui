           <item row="0" column="1">
            <widget class="qMRMLNodeComboBox" name="cbRedDisplayVolume">
             <property name="nodeTypes">
              <stringlist>
               <string>vtkMRMLScalarVolumeNode</string>
              </stringlist>
             </property>
             <property name="noneEnabled">
              <bool>true</bool>
             </property>
             <property name="addEnabled">
              <bool>false</bool>
             </property>
             <property name="removeEnabled">
              <bool>false</bool>
             </property>
             <property name="renameEnabled">
              <bool>false</bool>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="lblYellowDisplayVolume">
             <property name="text">
              <string>Yellow (Sagittal):</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="qMRMLNodeComboBox" name="cbYellowDisplayVolume">
             <property name="nodeTypes">
              <stringlist>
               <string>vtkMRMLScalarVolumeNode</string>
              </stringlist>
             </property>
             <property name="noneEnabled">
              <bool>true</bool>
             </property>
             <property name="addEnabled">
              <bool>false</bool>
             </property>
             <property name="removeEnabled">
              <bool>false</bool>
             </property>
             <property name="renameEnabled">
              <bool>false</bool>
             </property>
            </widget>
           </item>
           <item row="2" column="0">
            <widget class="QLabel" name="lblGreenDisplayVolume">
             <property name="text">
              <string>Green (Coronal):</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="qMRMLNodeComboBox" name="cbGreenDisplayVolume">
             <property name="nodeTypes">
              <stringlist>
               <string>vtkMRMLScalarVolumeNode</string>
              </stringlist>
             </property>
             <property name="noneEnabled">
              <bool>true</bool>
             </property>
             <property name="addEnabled">
              <bool>false</bool>
             </property>
             <property name="removeEnabled">
              <bool>false</bool>
             </property>
             <property name="renameEnabled">
              <bool>false</bool>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         <item>
         <layout class="QHBoxLayout" name="horizontalLayout_planeDisplayActions">
           <item>
            <widget class="QPushButton" name="pbApplyPlaneDisplayVolumes">
             <property name="toolTip">
              <string>Use the selected registered volumes as the Red, Yellow, and Green slice-view backgrounds. Empty selections fall back to the current Segment Editor source volume.</string>
             </property>
             <property name="text">
              <string>Apply view volumes</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="pbResetPlaneDisplayVolumes">
             <property name="toolTip">
              <string>Restore the current Segment Editor source volume as the background in all three slice views.</string>
             </property>
             <property name="text">
              <string>Use source volume for all</string>
             </property>
            </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QCheckBox" name="cbSnapSlicesToGrid">
          <property name="toolTip">
           <string>For obliquely acquired series, the standard axial/sagittal/coronal views reslice the volume at an angle, so scrolling never lands on the real acquired slices. Enable this to rotate the slice views to the series' own acquisition planes: the image is straightened, the slice-intersection cross follows the real series axes, and one view scrolls through the original slices. Axis-aligned series are left unchanged.</string>
          </property>
          <property name="text">
           <string>Align views to the acquisition plane for oblique series</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="highResOutputGroup">
          <property name="title">
           <string>High-resolution output (optional)</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_highResOutput">
           <item>
            <widget class="QCheckBox" name="cbEnableHighResOutput">
             <property name="toolTip">
              <string>Store the segment on a high-resolution isotropic grid instead of the coarse source volume, so results stay sharp in all three planes. A larger field of view at fine spacing uses more memory.</string>
             </property>
             <property name="text">
              <string>Store masks on a high-resolution isotropic grid</string>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QFormLayout" name="formLayout_highResOutput">
             <item row="0" column="0">
              <widget class="QLabel" name="lblOutputSpacing">
               <property name="text">
                <string>Isotropic spacing (mm, 0 = auto):</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QDoubleSpinBox" name="sbOutputSpacing">
               <property name="decimals">
                <number>2</number>
               </property>
               <property name="minimum">
                <double>0.000000000000000</double>
               </property>
               <property name="maximum">
                <double>10.000000000000000</double>
               </property>
               <property name="singleStep">
                <double>0.100000000000000</double>
               </property>
               <property name="value">
                <double>0.000000000000000</double>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QCheckBox" name="cbSmoothInterpolate">
             <property name="toolTip">
              <string>Interpolate each coarse segmentation result onto the high-resolution grid using shape-based (signed-distance) interpolation, so the boundary is smooth in all three planes instead of stair-stepped. Requires the high-resolution output grid; enabling this turns it on automatically.</string>
             </property>
             <property name="text">
              <string>Smooth (interpolate) result between slices</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="pbSmoothCurrentSegment">
             <property name="toolTip">
              <string>Re-run shape-based smoothing on the whole current segment, e.g. after erasing or other manual edits. Requires the high-resolution output grid; clicking enables it if needed. Undoable from the Segment Editor.</string>
             </property>
             <property name="text">
              <string>Smooth current segment</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="lblHighResOutputHelp">
             <property name="text">
              <string>Note: a single inference on the coarse source volume stays coarse. Enable smoothing above to interpolate it, or run native-series inference on each high-resolution series and merge.</string>
             </property>
             <property name="wordWrap">
              <bool>true</bool>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="nativeSeriesInferenceGroup">
          <property name="title">
           <string>Native-series inference (optional)</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_nativeSeriesInference">
           <item>
            <widget class="QCheckBox" name="cbEnableNativeSeriesInference">
             <property name="toolTip">
              <string>Run nnInteractive on a registered supplemental series. Results are previewed first and synchronized back to the Segment Editor source volume only when confirmed.</string>
             </property>
             <property name="text">
              <string>Analyze a supplemental series</string>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QFormLayout" name="formLayout_nativeSeriesInference">
             <item row="0" column="0">
              <widget class="QLabel" name="lblInferenceWorkingVolume">
               <property name="text">
                <string>Working volume:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="qMRMLNodeComboBox" name="cbInferenceWorkingVolume">
               <property name="nodeTypes">
                <stringlist>
                 <string>vtkMRMLScalarVolumeNode</string>
                </stringlist>
               </property>
               <property name="noneEnabled">
                <bool>true</bool>
               </property>
               <property name="addEnabled">
                <bool>false</bool>
               </property>
               <property name="removeEnabled">
                <bool>false</bool>
               </property>
               <property name="renameEnabled">
                <bool>false</bool>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="lblInferenceSyncMode">
               <property name="text">
                <string>Sync mode:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QComboBox" name="cbInferenceSyncMode">
               <item>
                <property name="text">
                 <string>Add to source</string>
                </property>
               </item>
               <item>
                <property name="text">
                 <string>Replace source</string>
                </property>
               </item>
               <item>
                <property name="text">
                 <string>Subtract from source</string>
                </property>
               </item>
               <item>
                <property name="text">
                 <string>Intersect source</string>
                </property>
               </item>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout_nativeSeriesInferenceActions">
             <item>
              <widget class="QPushButton" name="pbSyncInferenceResult">
               <property name="toolTip">
                <string>Merge the current supplemental-series preview into the Segment Editor source volume using the selected sync mode.</string>
               </property>
               <property name="text">
                <string>Sync preview to source</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="pbClearInferencePreview">
               <property name="toolTip">
                <string>Discard the supplemental-series preview without changing the source segment.</string>
               </property>
               <property name="text">
                <string>Clear preview</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QCheckBox" name="cbAutoRegisterSupplemental">
             <property name="toolTip">
              <string>When the supplemental series uses a different DICOM frame of reference than the source volume (for example after a mid-exam localizer or repositioning), automatically run a rigid registration so prompts and masks land in the correct place.</string>
             </property>
             <property name="text">
              <string>Auto-register supplemental series to source</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QCheckBox" name="cbConfirmSeriesAligned">
             <property name="toolTip">
              <string>Skip registration when the DICOM frame of reference cannot be read. Only check this if you are certain the supplemental series is already aligned with the source volume.</string>
             </property>
             <property name="text">
              <string>I confirm these series are already aligned (skip registration)</string>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout_seriesAlignmentMode">
             <item>
              <widget class="QLabel" name="lblRegistrationMode">
               <property name="text">
                <string>Registration:</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QComboBox" name="cbRegistrationMode">
               <property name="toolTip">
                <string>Rigid handles patient motion and repositioning. Use Affine only when a rigid fit leaves a large residual.</string>
               </property>
               <item>
                <property name="text">
                 <string>Rigid</string>
                </property>
               </item>
               <item>
                <property name="text">
                 <string>Affine</string>
                </property>
               </item>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout_seriesAlignmentActions">
             <item>
              <widget class="QPushButton" name="pbRegisterSupplemental">
               <property name="toolTip">
                <string>Manually register the current working volume to the source volume now, regardless of frame-of-reference detection.</string>
               </property>
               <property name="text">
                <string>Register now</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="pbClearAlignment">
               <property name="toolTip">
                <string>Remove any registration transforms and return the supplemental series to its original position.</string>
               </property>
               <property name="text">
                <string>Clear alignment</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QLabel" name="lblRegistrationStatus">
             <property name="text">
              <string/>
             </property>
             <property name="wordWrap">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="lblNativeSeriesInferenceHelp">
             <property name="text">
              <string>Prompts run on the working volume. The result remains a preview until synchronized to the source volume.</string>
             </property>
             <property name="wordWrap">
              <bool>true</bool>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        </layout>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_segOpacity">
        <item>
         <widget class="QLabel" name="lblSegOpacity">
          <property name="text">
           <string>Opacity:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QSlider" name="sldSegmentOpacity">
          <property name="toolTip">
           <string>Display opacity of the currently selected segment (2D fill, outline, and 3D combined).</string>
          </property>
          <property name="minimum">
           <number>0</number>
          </property>
          <property name="maximum">
           <number>100</number>
          </property>
          <property name="value">
           <number>100</number>
          </property>
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="lblSegOpacityValue">
          <property name="minimumSize">
           <size>
            <width>48</width>
            <height>0</height>
           </size>
          </property>
          <property name="text">
           <string>100 %</string>
          </property>
          <property name="alignment">
           <set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_lassoClip">
        <item>
         <widget class="QCheckBox" name="cbEnableLassoClip">
          <property name="text">
           <string>Limit lasso result to +/- N slices</string>
          </property>
          <property name="toolTip">
           <string>When checked, a lasso result is cropped to the lasso slice plus/minus N slices along the lasso plane axis. Only affects the Lasso tool.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="lblLassoClipN">
          <property name="text">
           <string>+/- slices:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QSpinBox" name="sbLassoClipN">
          <property name="toolTip">
           <string>0 keeps only the lasso slice.</string>
          </property>
          <property name="minimum">
           <number>0</number>
          </property>
          <property name="maximum">
           <number>200</number>
          </property>
          <property name="value">
           <number>0</number>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QGroupBox" name="displaySmoothGroup">
        <property name="title">
         <string>Display smoothing (non-destructive)</string>
        </property>
        <layout class="QVBoxLayout" name="verticalLayout_displaySmooth">
         <item>
          <widget class="QCheckBox" name="cbDisplaySmooth">
           <property name="toolTip">
            <string>Smooth only the display: both the 2D slice outlines and the 3D surface are rendered from a smoothed closed surface, while the stored segment labelmap is left unchanged. Independent of the Smooth (interpolate) data option above. Use Bake to make the smoothed shape the stored data (for export).</string>
           </property>
           <property name="text">
            <string>Smooth display only (2D + 3D, non-destructive)</string>
           </property>
          </widget>
         </item>
         <item>
          <layout class="QFormLayout" name="formLayout_displaySmooth">
           <item row="0" column="0">
            <widget class="QLabel" name="lblDisplaySmoothStrength">
             <property name="text">
              <string>Strength:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QDoubleSpinBox" name="sbDisplaySmoothStrength">
             <property name="toolTip">
              <string>Surface smoothing strength (0 = none, 1 = maximal).</string>
             </property>
             <property name="minimum">
              <double>0.000000000000000</double>
             </property>
             <property name="maximum">
              <double>1.000000000000000</double>
             </property>
             <property name="singleStep">
              <double>0.100000000000000</double>
             </property>
             <property name="value">
              <double>0.500000000000000</double>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         <item>
          <widget class="QPushButton" name="pbBakeDisplaySmooth">
           <property name="toolTip">
            <string>Bake the currently displayed smooth surface into the segment labelmap (destructive, on demand). After baking, what is stored matches what is shown, so the smoothed result can be exported. The original is restored if the conversion fails.</string>
           </property>
           <property name="text">
            <string>Bake smoothed surface into segment</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QLabel" name="lblDisplaySmoothHelp">
           <property name="text">
            <string>Display only: the stored mask stays as-is until you click Bake.</string>
           </property>
           <property name="wordWrap">
            <bool>true</bool>
           </property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>
      <item>
       <widget class="qMRMLSegmentEditorWidget" name="editor_widget">
        <property name="defaultTerminologyEntrySettingsKey">
         <string notr="true"/>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
